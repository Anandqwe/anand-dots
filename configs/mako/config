# ╔══════════════════════════════════════════════╗
# ║         anand-dots — Mako Config              ║
# ║         Theme: material-you                 ║
# ╚══════════════════════════════════════════════╝

# ── Font ────────────────────────────────────────
font=JetBrainsMono Nerd Font 11

# ── Colors ──────────────────────────────────────
background-color=#191211ee
text-color=#f3e3e2
border-color=#ffb3ad

# ── Layout ──────────────────────────────────────
width=350
height=100
margin=8
padding=12
border-size=2
border-radius=8

# ── Behavior ────────────────────────────────────
default-timeout=5000
max-visible=3
anchor=top-right
layer=overlay

# ── Icons ───────────────────────────────────────
icons=1
max-icon-size=48

# ── Urgency: Low ───────────────────────────────
[urgency=low]
border-color=#221b1a

# ── Urgency: Normal ────────────────────────────
[urgency=normal]
border-color=#ffb3ad

# ── Urgency: Critical ──────────────────────────
[urgency=critical]
border-color=#ffb4ab
default-timeout=0
