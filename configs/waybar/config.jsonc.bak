{
  "layer": "top",
  "position": "top",
  "height": 34,
  "spacing": 6,

  "modules-left": [
    "hyprland/workspaces"
  ],

  "modules-center": [
    "hyprland/window"
  ],

  "modules-right": [
    "pulseaudio",
    "network",
    "bluetooth",
    "battery",
    "clock",
    "tray",
    "custom/power"
  ],

  "hyprland/window": {
    "format": "{}",
    "max-length": 60
  },

  "hyprland/workspaces": {
    "format": "{windows}",
    "format-window-separator": " ",
    "window-rewrite-default": "ΎΜΡ",
    "window-rewrite": {
      "class<firefox>": "ΌζΖ",
      "class<chromium>": "ΌζΔ",
      "class<brave-browser>": "ΌζΔ",
      "class<google-chrome>": "ΌζΔ",
      "class<kitty>": "ΎΤΚ",
      "class<alacritty>": "ΎΤΚ",
      "class<foot>": "ΎΤΚ",
      "class<code>": "≤░ρη",
      "class<code-oss>": "≤░ρη",
      "class<codium>": "≤░ρη",
      "class<cursor>": "≤░ρη",
      "class<thunar>": "≤░Με",
      "class<nautilus>": "≤░Με",
      "class<org.gnome.Nautilus>": "≤░Με",
      "class<spotify>": "ΎΗ╝",
      "class<discord>": "≤░βψ",
      "class<vesktop>": "≤░βψ",
      "class<telegram-desktop>": "ΎΜΗ",
      "class<obsidian>": "≤░╢▒",
      "class<gimp>": "Όης",
      "class<inkscape>": "Όη┤",
      "class<vlc>": "≤░Χ╝",
      "class<mpv>": "ΎΖΕ",
      "class<steam>": "ΎΗ╢",
      "class<lutris>": "ΎΕδ",
      "class<org.pwmt.zathura>": "≤░Ιβ",
      "class<evince>": "≤░Ιβ",
      "title<.*nvim.*>": "Όατ",
      "title<.*vim.*>": "Όατ",
      "title<.*YouTube.*>": "ΎΖπ"
    },
    "persistent-workspaces": {
      "*": 5
    },
    "on-click": "activate",
    "on-scroll-up": "hyprctl dispatch workspace e+1",
    "on-scroll-down": "hyprctl dispatch workspace e-1"
  },

  "clock": {
    "format": "ΎΑΩ  {:%a %b %d  %H:%M}",
    "tooltip-format": "<tt>{calendar}</tt>"
  },

  "cpu": {
    "interval": 5,
    "format": "ΎΜδ  {usage}%"
  },

  "memory": {
    "interval": 5,
    "format": "ΎΦ╕  {}%"
  },

  "battery": {
    "interval": 30,
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "{icon} {capacity}%",
    "format-icons": [
      "ΎΚΕ",
      "ΎΚΔ",
      "ΎΚΓ",
      "ΎΚΒ",
      "ΎΚΑ"
    ]
  },

  "bluetooth": {
    "format": "ΎΛΦ",
    "format-connected": "ΎΛΦ  {device_alias}",
    "on-click": "blueman-manager"
  },

  "network": {
    "interval": 5,
    "format-wifi": "ΎΘτ  {essid}",
    "format-ethernet": "≤░ΙΑ  {ifname}",
    "format-disconnected": "ΎΒ▒  Offline"
  },

  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-muted": "≤░ζθ Muted",
    "format-icons": {
      "default": [
        "ΎΑο",
        "ΎΑπ",
        "ΎΑρ"
      ]
    },
    "on-click": "pamixer -t",
    "on-scroll-up": "pamixer -i 5",
    "on-scroll-down": "pamixer -d 5"
  },

  "tray": {
    "icon-size": 16,
    "spacing": 8
  },

  "custom/power": {
    "format": "ΎΑΣ",
    "tooltip": false,
    "on-click": "~/.config/hypr/scripts/powermenu.sh"
  }
}