/* ╔══════════════════════════════════════════════╗ */
/* ║       anand-dots — Rofi Colors Template      ║ */
/* ║       Theme: {{theme_name}}                  ║ */
/* ╚══════════════════════════════════════════════╝ */

* {
    /* ── Base surfaces ──────────────────── */
    base:           {{base}};
    mantle:         {{mantle}};
    crust:          {{crust}};

    /* ── Overlay surfaces ───────────────── */
    surface0:       {{surface0}};
    surface1:       {{surface1}};
    surface2:       {{surface2}};

    /* ── Text ───────────────────────────── */
    text:           {{text}};
    subtext1:       {{subtext1}};
    subtext0:       {{subtext0}};
    overlay2:       {{overlay2}};

    /* ── Accent colors ──────────────────── */
    blue:           {{blue}};
    sky:            {{sky}};
    teal:           {{teal}};
    mauve:          {{mauve}};
    lavender:       {{lavender}};
    green:          {{green}};
    yellow:         {{yellow}};
    peach:          {{peach}};
    red:            {{red}};

    /* ── Transparency helpers ───────────── */
    bg-transparent: rgba(0, 0, 0, 0.0);
}
